\par \pard\plain {\listtext\pard\plain \li360\ri0\lin360\rin0\fi-360\sa120 3.\tab}\ilvl0 \ltrpar\s3\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\sa120\rtlch\af4\afs24\lang255\ltrch\dbch\af4\langfe255\hich\f1\fs24\lang1038\loch\f1\fs24\lang1038 {\rtlch \ltrch\loch\f1\fs24\lang1038\i0\b0 Mi a k\'f6nyv c\'edme (alc\'edmmel)? \line }
